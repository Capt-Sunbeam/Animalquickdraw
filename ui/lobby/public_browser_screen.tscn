horizontal_alignment = 1

[node name="RetryButton" type="Button" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 4
visible = false
text = "Retry"

[node name="NoticeDialog" parent="." instance=ExtResource("2_notice")]
unique_name_in_owner = true

[node name="Toast" parent="." instance=ExtResource("3_toast")]
