theme_override_constants/margin_bottom = 12

[node name="Root" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="TopBar" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="BackButton" type="Button" parent="Margin/Root/TopBar"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(90, 36)
text = "< Back"

[node name="TitleLabel" type="Label" parent="Margin/Root/TopBar"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 26
