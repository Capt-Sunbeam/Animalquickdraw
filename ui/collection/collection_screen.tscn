[node name="Scroll" type="ScrollContainer" parent="Margin/Root"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="Grid" type="GridContainer" parent="Margin/Root/Scroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 4
theme_override_constants/h_separation = 12
theme_override_constants/v_separation = 12

[node name="EmptyState" type="Label" parent="Margin/Root"]
unique_name_in_owner = true
visible = false
layout_mode = 2
size_flags_vertical = 3
text = "No drawings yet.
Give a kudos in-game, or flip on 'Save to collection' while drawing — they'll show up here."
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 2

[node name="Viewer" parent="." instance=ExtResource("2_viewer")]
