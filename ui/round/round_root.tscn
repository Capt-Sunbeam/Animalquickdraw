[gd_scene load_steps=6 format=3]

[ext_resource type="Script" path="res://ui/round/round_root.gd" id="1_rroot"]
[ext_resource type="Script" path="res://game/session/session_client.gd" id="2_sclient"]
[ext_resource type="PackedScene" path="res://ui/shared/chat_panel.tscn" id="3_chat"]
[ext_resource type="PackedScene" path="res://ui/shared/toast.tscn" id="4_toast"]
[ext_resource type="PackedScene" path="res://ui/round/game_menu.tscn" id="5_menu"]

[node name="RoundRoot" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_rroot")

[node name="SessionClient" type="Node" parent="."]
unique_name_in_owner = true
script = ExtResource("2_sclient")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 12

[node name="Root" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="PhaseArea" type="Control" parent="Margin/Root"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="WaitingLabel" type="Label" parent="Margin/Root/PhaseArea"]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -120.0
offset_top = -13.0
offset_right = 120.0
offset_bottom = 13.0
grow_horizontal = 2
grow_vertical = 2
theme_override_font_sizes/font_size = 20
text = "Get ready..."
horizontal_alignment = 1

[node name="Chat" parent="Margin/Root" instance=ExtResource("3_chat")]
unique_name_in_owner = true
layout_mode = 2

[node name="Toast" parent="." instance=ExtResource("4_toast")]
unique_name_in_owner = true

[node name="Menu" parent="." instance=ExtResource("5_menu")]
unique_name_in_owner = true
layout_mode = 1
